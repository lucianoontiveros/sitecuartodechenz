# Configuración de MongoDB (SOLO backend - NUNCA en frontend)
MONGODB_USERNAME=tu_usuario_mongodb
MONGODB_PASSWORD=tu_password_mongodb
MONGODB_CLUSTER=tu_cluster.mongodb.net
MONGODB_DATABASE=nombre_base_datos

# Configuración de Google OAuth
# Frontend: Solo necesita el Client ID para OAuth
VITE_GOOGLE_CLIENT_ID=tu_google_client_id
# Backend: Verificación de tokens
GOOGLE_CLIENT_ID=tu_google_client_id

# Configuración de JWT (SOLO backend - NUNCA en frontend)
JWT_SECRET=tu_jwt_secret_key_muy_segura

# Emails autorizados para administración (separados por coma)
# Ejemplo con un solo email:
AUTHORIZED_EMAILS=luciano.a.ontiveros@gmail.com,lucianotaaxii@gmail.com
# Ejemplo con múltiples emails:
# AUTHORIZED_EMAILS=luciano.a.ontiveros@gmail.com,otro@email.com,tercero@email.com

# URL del backend API (importante para Netlify)
VITE_API_URL=https://sitecuartodechenz-backend.onrender.com/api

# URL del frontend (para CORS)
VITE_FRONTEND_URL=http://localhost:5173

# Puerto del servidor (opcional, default: 3001)
PORT=3001
